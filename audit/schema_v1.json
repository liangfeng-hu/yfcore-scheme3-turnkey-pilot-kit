{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scheme-3 AuditCard v1",
  "type": "object",
  "required": [
    "version",
    "ts_ms",
    "req_id",
    "gatevector_len",
    "ssot_hash",
    "canon_header",
    "ledger_root",
    "seed_t",
    "evidence_hash",
    "evidence_canon",
    "i_ledger_ok",
    "gate90_ok",
    "gate91_ok",
    "lse_ok",
    "i_flow",
    "commit_unique",
    "world_writeback",
    "out_level",
    "reason_code",
    "audit_receipt_hash"
  ],
  "properties": {
    "version": { "type": "string" },
    "ts_ms": { "type": "integer" },
    "req_id": { "type": "string" },
    "gatevector_len": { "type": "integer", "const": 91 },
    "ssot_hash": { "type": "string" },
    "canon_header": { "type": "string" },
    "ledger_root": { "type": "string" },
    "seed_t": { "type": "string" },
    "evidence_hash": { "type": "string" },
    "evidence_canon": { "type": "string" },
    "i_ledger_ok": { "type": "integer", "enum": [0, 1] },
    "gate90_ok": { "type": "integer", "enum": [0, 1] },
    "gate91_ok": { "type": "integer", "enum": [0, 1] },
    "lse_ok": { "type": "integer", "enum": [0, 1] },
    "i_flow": { "type": "string", "enum": ["0", "+∞"] },
    "commit_unique": { "type": "integer", "enum": [0, 1] },
    "world_writeback": { "type": "integer", "enum": [0, 1] },
    "out_level": { "type": "string", "enum": ["ShadowOnly", "EvidencePlan", "FOES"] },
    "reason_code": { "type": "string" },
    "audit_receipt_hash": { "type": "string" }
  }
}
